rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- Global Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function isAdmin() { 
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email in ["mutaz2838@gmail.com", "GCC@gccgr.com"]
      );
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entry Point Deny ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Projects Collection ---
    match /projects/{projectId} {
      function isValidProject(data) {
        return data.keys().hasAll(['title', 'category', 'image', 'description', 'createdAt', 'updatedAt'])
        && data.keys().size() <= 8
        && data.title is string && data.title.size() <= 200
        && data.category in ["Firefighting Systems", "HVAC & Cooling", "Power Generators", "Alarm & Control Systems", "CCTV & Security Cameras"]
        && data.image is string && data.image.size() <= 500
        && data.description is string && data.description.size() <= 5000
        && (data.get('duration', '') is string)
        && (data.get('client', '') is string)
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
      }

      allow read: if true;
      
      allow create: if isAdmin() 
        && isValidProject(incoming())
        && incoming().createdAt == request.time
        && incoming().updatedAt == request.time;
        
      allow update: if isAdmin()
        && isValidProject(incoming())
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
        
      allow delete: if isAdmin();
    }

    // --- Admins Collection ---
    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if isAdmin(); // In production, usually only super-admins
    }

    // --- Quotations Collection ---
    match /quotations/{quoteId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // --- Settings Collection ---
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
